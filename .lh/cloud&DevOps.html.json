            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Black+Ops+One&family=DM+Serif+Display:ital@0;1&family=Electrolize&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap\">\r\n    <title>Cloud & DevOps - TechCareer Explorer</title>\r\n     <link rel=\"stylesheet\" href=\"CSS/cloud.css\">\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- ============ HEADER ============ -->\r\n    <header>\r\n        <a class=\"head-icon\" href=\"#\">\r\n            <div class=\"image-icon\">\r\n                <img src=\"images/Icon.png\" alt=\"TechCareer Explorer logo\" height=\"60\" width=\"60\">\r\n            </div>\r\n            <span class=\"nav-left\">TechCareer·Explorer</span>\r\n        </a>\r\n\r\n        <button class=\"menu-btn\" aria-label=\"Toggle navigation menu\">\r\n            <i class=\"fa fa-cog\"></i>\r\n        </button>\r\n\r\n        <ul class=\"navbar\" id=\"navLinks\">\r\n            <li>\r\n                <a class=\"nav-one\" href=\"index.html\">\r\n                    <i class=\"fa-solid fa-house\"></i>\r\n                    Home\r\n                </a>\r\n            </li>\r\n\r\n            <li class=\"dropdown\">\r\n                <a href=\"#\" class=\"nav-other dropdown-toggle\">\r\n                    <i class=\"fa-solid fa-briefcase\"></i>\r\n                    Category Roles\r\n                    <i class=\"fa-solid fa-chevron-down\"></i>\r\n                </a>\r\n                <ul class=\"dropdown-menu\">\r\n                    <li><a href=\"web-development.html\">Web Developer</a></li>\r\n                    <li><a href=\"mobile-development.html\">Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">AI & Machine Learning</a></li>\r\n                    <li><a href=\"data-Analytics.html\">Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">Game Development</a></li>\r\n                </ul>\r\n            </li>\r\n        </ul>\r\n    </header>\r\n\r\n    <!-- ============ HERO SECTION ============ -->\r\n    <div class=\"hero\">\r\n        <h1>Cloud & DevOps</h1>\r\n        <p>Build, deploy, and scale cloud infrastructure. Master cloud platforms, containerization, CI/CD, and infrastructure automation.</p>\r\n    </div>\r\n\r\n    <!-- ============ MAIN CONTAINER ============ -->\r\n    <div class=\"container\">\r\n\r\n        <!-- ============ CAREER PATHS ============ -->\r\n        <section id=\"careers\">\r\n            <h2>Choose Your Cloud & DevOps Path</h2>\r\n            <div class=\"cards-container\">\r\n                <div class=\"card\">\r\n                    <h3>Cloud Engineer</h3>\r\n                    <p>Design and implement cloud infrastructure solutions on AWS, Azure, or GCP.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>AWS/Azure/GCP</li>\r\n                        <li>Infrastructure as Code</li>\r\n                        <li>Networking</li>\r\n                        <li>Databases</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>DevOps Engineer</h3>\r\n                    <p>Automate deployment, testing, and infrastructure for continuous delivery.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Docker/Kubernetes</li>\r\n                        <li>CI/CD Pipelines</li>\r\n                        <li>Jenkins/GitLab</li>\r\n                        <li>Automation Scripts</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Site Reliability Engineer (SRE)</h3>\r\n                    <p>Ensure system reliability, performance, and availability using engineering practices.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Monitoring & Alerts</li>\r\n                        <li>Performance Tuning</li>\r\n                        <li>Incident Management</li>\r\n                        <li>System Design</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Cloud Architect</h3>\r\n                    <p>Design enterprise cloud solutions and strategies aligned with business goals.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Solution Design</li>\r\n                        <li>Cost Optimization</li>\r\n                        <li>Security & Compliance</li>\r\n                        <li>Cloud Strategy</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ DETAILED ROLES ============ -->\r\n        <section>\r\n            <h2>Cloud Engineer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You design and implement cloud infrastructure solutions. You work with cloud platforms like AWS, Azure, or GCP to build scalable, secure, and reliable systems.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Cloud Platforms - AWS, Azure, GCP services</li>\r\n                    <li>Infrastructure as Code - Terraform, CloudFormation, Ansible</li>\r\n                    <li>Networking - VPC, Security Groups, Load Balancing</li>\r\n                    <li>Databases - Managed databases, Data storage</li>\r\n                    <li>Linux/Windows Administration</li>\r\n                    <li>Scripting - Python, Bash, PowerShell</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹6 - 18 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Cloud Infrastructure Engineer</li>\r\n                    <li>Cloud Solutions Architect</li>\r\n                    <li>Cloud Platform Engineer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>DevOps Engineer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You automate deployment pipelines and infrastructure management. You bridge development and operations teams to enable continuous delivery.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Containerization - Docker, Docker Compose</li>\r\n                    <li>Orchestration - Kubernetes, ECS</li>\r\n                    <li>CI/CD Tools - Jenkins, GitLab CI, GitHub Actions</li>\r\n                    <li>Infrastructure as Code - Terraform, Ansible</li>\r\n                    <li>Scripting - Python, Bash, Go</li>\r\n                    <li>Git - Version control and collaboration</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹7 - 20 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>DevOps Engineer</li>\r\n                    <li>Release Engineer</li>\r\n                    <li>Deployment Specialist</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Site Reliability Engineer (SRE) Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You apply software engineering practices to ensure system reliability and performance. You manage incident response and drive continuous improvement.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Monitoring & Observability - Prometheus, ELK, Datadog</li>\r\n                    <li>Performance Analysis - Profiling, bottleneck identification</li>\r\n                    <li>Incident Management - On-call, Root cause analysis</li>\r\n                    <li>System Design - Scalability, High availability</li>\r\n                    <li>Programming - Python, Go, Java</li>\r\n                    <li>Cloud Platforms - AWS, GCP, Azure</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹8 - 22 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Site Reliability Engineer (SRE)</li>\r\n                    <li>Reliability Engineer</li>\r\n                    <li>Platform Engineer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Cloud Architect Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You design enterprise-level cloud solutions aligned with business objectives. You make strategic decisions about cloud adoption and technology choices.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Solution Architecture - Designing scalable systems</li>\r\n                    <li>Cloud Platforms - Deep knowledge of AWS/Azure/GCP</li>\r\n                    <li>Cost Optimization - Budget management, resource optimization</li>\r\n                    <li>Security & Compliance - Identity, encryption, regulations</li>\r\n                    <li>Business Acumen - Understanding business needs</li>\r\n                    <li>Communication - Presenting to stakeholders</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹15 - 40 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Cloud Solutions Architect</li>\r\n                    <li>Enterprise Cloud Architect</li>\r\n                    <li>Chief Technology Officer (CTO)</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ SKILLS COMPARISON ============ -->\r\n        <section>\r\n            <h2>Skills Comparison Table</h2>\r\n            <div class=\"table-wrapper\">\r\n            <table>\r\n                <thead>\r\n                    <tr>\r\n                        <th>Skills</th>\r\n                        <th>Cloud Engineer</th>\r\n                        <th>DevOps Engineer</th>\r\n                        <th>Site Reliability Engineer</th>\r\n                        <th>Cloud Architect</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    <tr>\r\n                        <td>Cloud Platforms (AWS/Azure/GCP)</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Infrastructure as Code</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Docker & Kubernetes</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"cross\">✗</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>CI/CD Pipelines</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"cross\">✗</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Monitoring & Observability</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Programming (Python/Go/Java)</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"cross\">✗</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Networking & Security</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Cost Optimization</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Business Acumen</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Incident Management</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"cross\">✗</td>\r\n                    </tr>\r\n                </tbody>\r\n            </table>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ ROADMAP ============ -->\r\n        <section id=\"roadmap\">\r\n            <h2>Cloud & DevOps Learning Roadmap</h2>\r\n            <div class=\"roadmap-list\">\r\n                <h3>Step-by-Step Learning Path</h3>\r\n                <ol>\r\n                    <li><strong>Month 1-2:</strong> Linux fundamentals - command line, file systems, permissions</li>\r\n                    <li><strong>Month 2-3:</strong> Networking basics - TCP/IP, DNS, HTTP/HTTPS</li>\r\n                    <li><strong>Month 3-4:</strong> One cloud platform - AWS, Azure, or GCP fundamentals</li>\r\n                    <li><strong>Month 4-5:</strong> Container basics - Docker, containerization concepts</li>\r\n                    <li><strong>Month 5-6:</strong> Infrastructure as Code - Terraform, CloudFormation</li>\r\n                    <li><strong>Month 6-7:</strong> CI/CD pipelines - Jenkins, GitLab, GitHub Actions</li>\r\n                    <li><strong>Month 7-8:</strong> Kubernetes or advanced cloud topics</li>\r\n                    <li><strong>Month 8-10:</strong> Choose specialization - DevOps, SRE, or Architecture</li>\r\n                    <li><strong>Month 10+:</strong> Get certified - AWS, Azure, or Kubernetes certifications</li>\r\n                </ol>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ TECHNOLOGIES ============ -->\r\n        <section id=\"resources\">\r\n            <h2>Popular Cloud & DevOps Technologies</h2>\r\n            <div class=\"tech-grid\">\r\n                <div class=\"tech-item\">AWS</div>\r\n                <div class=\"tech-item\">Azure</div>\r\n                <div class=\"tech-item\">Google Cloud</div>\r\n                <div class=\"tech-item\">Docker</div>\r\n                <div class=\"tech-item\">Kubernetes</div>\r\n                <div class=\"tech-item\">Terraform</div>\r\n                <div class=\"tech-item\">Jenkins</div>\r\n                <div class=\"tech-item\">GitLab CI</div>\r\n                <div class=\"tech-item\">Ansible</div>\r\n                <div class=\"tech-item\">Prometheus</div>\r\n                <div class=\"tech-item\">ELK Stack</div>\r\n                <div class=\"tech-item\">Datadog</div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ PROJECT IDEAS ============ -->\r\n        <section>\r\n            <h2>Project Ideas to Practice</h2>\r\n            <div class=\"projects-grid\">\r\n                <div class=\"project-item\">Deploy App to AWS</div>\r\n                <div class=\"project-item\">Create CI/CD Pipeline</div>\r\n                <div class=\"project-item\">Kubernetes Cluster Setup</div>\r\n                <div class=\"project-item\">Infrastructure as Code</div>\r\n                <div class=\"project-item\">Docker Containerization</div>\r\n                <div class=\"project-item\">Monitoring Setup</div>\r\n                <div class=\"project-item\">Auto-scaling Application</div>\r\n                <div class=\"project-item\">Disaster Recovery Plan</div>\r\n            </div>\r\n        </section>\r\n\r\n        <section class=\"resources\">\r\n\r\n            <h3>📚 Free Learning Resources</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://aws.amazon.com/training/\" target=\"_blank\">AWS Training & Certification</a></li>\r\n\r\n                <li><a href=\"https://learn.microsoft.com/en-us/azure/\" target=\"_blank\">Microsoft Azure Learn</a></li>\r\n\r\n                <li><a href=\"https://www.docker.com/101-tutorial/\" target=\"_blank\">Docker Tutorial</a></li>\r\n\r\n                <li><a href=\"https://kubernetes.io/docs/tutorials/\" target=\"_blank\">Kubernetes Tutorials</a></li>\r\n\r\n                <li><a href=\"https://www.freecodecamp.org/news/devops/\" target=\"_blank\">freeCodeCamp DevOps</a></li>\r\n            </ul>\r\n\r\n            <h3>🎥 Free Video Tutorials</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://www.youtube.com/@AWSTraining\" target=\"_blank\">AWS Training</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@TechWorldwithNana\" target=\"_blank\">TechWorld with Nana</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@TraversyMedia\" target=\"_blank\">Traversy Media</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@CloudChampion\" target=\"_blank\">Cloud Champion</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@freecodecamp\" target=\"_blank\">freeCodeCamp</a></li>\r\n            </ul>\r\n\r\n        </section>\r\n\r\n        <!-- ============ FAQ ============ -->\r\n        <section id=\"faq\">\r\n            <h2>Frequently Asked Questions</h2>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the difference between Cloud Engineer and DevOps Engineer?</h4>\r\n                <p>Cloud Engineers focus on designing and implementing cloud infrastructure. DevOps Engineers focus on automating deployment and operations. Cloud Engineers build the foundation, DevOps Engineers automate the processes.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What is an SRE?</h4>\r\n                <p>A Site Reliability Engineer uses software engineering practices to ensure system reliability and performance. They focus on uptime, incident response, and continuous improvement.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Do I need to learn all cloud platforms?</h4>\r\n                <p>No. Start with one platform (AWS recommended). Once you master one, learning others is easier as concepts are similar. Focus on one initially for depth.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Should I start with Docker or Kubernetes?</h4>\r\n                <p>Start with Docker first. Docker is simpler and foundational. Once you understand Docker, learning Kubernetes becomes easier as it orchestrates Docker containers.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>How long does it take to learn Cloud & DevOps?</h4>\r\n                <p>Basics: 3-4 months. Intermediate: 6-8 months. Production-ready: 1-2 years. It depends on your background and hands-on experience.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Which cloud platform should I learn first?</h4>\r\n                <p>AWS is the most popular and has the most job opportunities. Learn AWS first. Azure is good for enterprise companies. GCP is gaining popularity in tech startups.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Do I need Linux knowledge for DevOps?</h4>\r\n                <p>Yes, Linux is essential for DevOps. Most servers run Linux. Learn Linux command line basics before diving into DevOps.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What certifications should I get?</h4>\r\n                <p>AWS Solutions Architect, AWS DevOps Engineer, Kubernetes Administrator (CKA), Azure Administrator. Start with one and progress from there.</p>\r\n            </div>\r\n        </section>\r\n\r\n    </div>\r\n\r\n    <!-- ============ FOOTER ============ -->\r\n    <footer class=\"footer\">\r\n        <div class=\"footer-container\">\r\n\r\n            <div class=\"footer-box\">\r\n                <div class=\"U\">\r\n                    <h2>Tech Career</h2>\r\n                    <p>\r\n                        Discover technology careers, explore learning paths,\r\n                        and build your future in the tech industry.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Quick Links</h3>\r\n                <ul>\r\n                    <li><a href=\"index.html\">➤ Home</a></li>\r\n                    <li><a href=\"index.html\">➤ Careers</a></li>\r\n                    <li><a href=\"index.html\">➤ Roadmaps</a></li>\r\n                    <li><a href=\"index.html\">➤ Resources</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Specializations</h3>\r\n                <ul>\r\n                    <li><a href=\"web-development.html\">➤ Web Development</a></li>\r\n                    <li><a href=\"mobile-development.html\">➤ Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">➤ AI & ML</a></li>\r\n                    <li><a href=\"data-Analytics.html\">➤ Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">➤ UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">➤ Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">➤ Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">➤ Game Development</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n           <div class=\"footer-box\">\r\n                <h3>Contact</h3>\r\n                <ul>\r\n                    <li><i class=\"fa-solid fa-envelope\"></i> : <a\r\n                            href=\"mailto:rk8938273@gmail.com\" target=\"_blank\">rk8938273@gmail.com</a></li>\r\n                    <li><i class=\"fa-solid fa-phone\"></i> : <a href=\"tel:+918005867249\"  target=\"_blank\">+91 8005867249</a></li>\r\n                    <li><i class=\"fa-brands fa-github\"></i> : <a href=\"https://github.com/Ravindra1807\"  target=\"_blank\">Ravindra1807</a>\r\n                    </li>\r\n                    <li><i class=\"fa-brands fa-linkedin\"></i> : <a\r\n                            href=\"https://www.linkedin.com/in/ravindra-kumar-a95761385\" target=\"_blank\">Ravindra Kumar</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n        </div>\r\n\r\n        <div class=\"footer-bottom\">\r\n            <p>© 2026 Tech Career Explorer. All Rights Reserved. | Developed by Ravindra Kumar</p>\r\n        </div>\r\n    </footer>\r\n\r\n    <script>\r\n        const menuBtn = document.querySelector(\".menu-btn\");\r\n        const navLinks = document.querySelector(\"#navLinks\");\r\n        const dropdowns = document.querySelectorAll(\".dropdown\");\r\n\r\n        // Mobile hamburger toggle\r\n        menuBtn.addEventListener(\"click\", (e) => {\r\n            e.stopPropagation();\r\n            navLinks.classList.toggle(\"active\");\r\n        });\r\n\r\n        // Close navbar + all dropdowns on outside click\r\n        document.addEventListener(\"click\", (e) => {\r\n            if (!navLinks.contains(e.target) && !menuBtn.contains(e.target)) {\r\n                navLinks.classList.remove(\"active\");\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n            }\r\n        });\r\n\r\n        // Dropdown toggle — 1 click open, same click close\r\n        dropdowns.forEach((dropdown) => {\r\n            const toggle = dropdown.querySelector(\".dropdown-toggle\");\r\n\r\n            toggle.addEventListener(\"click\", (e) => {\r\n                e.preventDefault();\r\n                e.stopPropagation();\r\n\r\n                const isOpen = dropdown.classList.contains(\"open\");\r\n\r\n                // close all first\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n\r\n                // toggle this one\r\n                if (!isOpen) dropdown.classList.add(\"open\");\r\n            });\r\n        });\r\n\r\n        // Clicks inside dropdown-menu don't close it\r\n        document.querySelectorAll(\".dropdown-menu\").forEach((menu) => {\r\n            menu.addEventListener(\"click\", (e) => e.stopPropagation());\r\n        });\r\n    </script>\r\n\r\n</body>\r\n\r\n</html>"
